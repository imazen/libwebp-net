<?xml version="1.0" encoding="utf-8" ?>
<Project ToolsVersion="12.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- Copy native DLLs to output for .NET Framework projects.
       .NET Core/5+ handles runtimes/ natively via deps.json. -->
  <Target Name="CopyWebPNativeLibs_win_x86"
          AfterTargets="Build"
          Condition=" '$(TargetFrameworkIdentifier)' != '.NETCoreApp' ">
    <ItemGroup>
      <_WebPNativeFiles_win_x86 Include="$(MSBuildThisFileDirectory)../../runtimes/win-x86/native/*" />
    </ItemGroup>
    <Copy SourceFiles="@(_WebPNativeFiles_win_x86)"
          DestinationFolder="$(OutputPath)\runtimes\win-x86\native"
          SkipUnchangedFiles="true" />
  </Target>
</Project>
